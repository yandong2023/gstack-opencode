{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1"
      },
      "models": {
        "deepseek-coder": {
          "name": "DeepSeek Coder V2"
        },
        "deepseek-chat": {
          "name": "DeepSeek Chat"
        }
      }
    },
    "kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi (Moonshot)",
      "options": {
        "baseURL": "https://api.moonshot.cn/v1"
      },
      "models": {
        "moonshot-v1-8k": {
          "name": "Kimi 8k"
        },
        "moonshot-v1-32k": {
          "name": "Kimi 32k"
        },
        "moonshot-v1-128k": {
          "name": "Kimi 128k"
        }
      }
    },
    "openai": {
      "name": "OpenAI",
      "models": {
        "gpt-4o": { "name": "GPT-4o" }
      }
    },
    "anthropic": {
      "name": "Anthropic",
      "models": {
        "claude-3-5-sonnet-latest": { "name": "Claude 3.5 Sonnet" }
      }
    },
    "google": {
      "name": "Google Gemini",
      "models": {
        "gemini-1.5-pro-latest": { "name": "Gemini 1.5 Pro" }
      }
    },
    "github": {
      "name": "GitHub Copilot",
      "models": {
        "copilot-codex": { "name": "Codex" }
      }
    }
  }
}
